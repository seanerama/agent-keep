# Template for /etc/agent-keep/default-chatbot.env (root-owned, mode 0600 — see
# .verity/deploy-access.md). deploy.sh WRITES the digest-pinned deploy vars here;
# the ONE secret VALUE (ANTHROPIC_API_KEY) is appended on the host at deploy time.
# Variable NAMES only in this file and in git — values never live in git or an
# image (agent-spec rule 3).
#
# This is the per-chassis env for the paired topology the systemd unit
# (deploy/systemd/agent-keep@.service) stands up: worker + egress-proxy + mechanic.

# --- Digest-pinned image refs (written by deploy.sh; ghcr.io/...@sha256:...) ---
# The worker image is the default chatbot; the version arg to deploy.sh selects
# its tag before pinning. The proxy + mechanic are the generic published images
# (default tag `edge`, overridable — see deploy.sh).
WORKER_IMAGE_REF=          # ghcr.io/seanerama/agent-keep-default-chatbot@sha256:...
PROXY_IMAGE_REF=           # ghcr.io/seanerama/agent-keep-egress-proxy@sha256:...
MECHANIC_IMAGE_REF=        # ghcr.io/seanerama/agent-keep-mechanic@sha256:...

# --- sha256 image digests (recorded into every audit line by the runtime) ---
WORKER_IMAGE_DIGEST=       # sha256:... (the WORKER_IMAGE_REF digest, bare)
MECHANIC_IMAGE_DIGEST=     # sha256:... (the MECHANIC_IMAGE_REF digest, bare)

# --- Host bind interface + per-surface ports (see deploy.sh port map) ---
# 127.0.0.1 keeps both dev-http surfaces reachable only from the host itself
# (correct for the tailnet dev chassis; a public route is a later ADR).
BIND_HOST=                 # e.g. 127.0.0.1
WORKER_BIND_PORT=          # worker dev-http host port (default-chatbot -> 8377)
MECHANIC_BIND_PORT=        # mechanic owner-console host port (default-chatbot -> 8477)

# --- Worker sqlite session store (INSIDE the container, on the /tmp tmpfs) ---
# The sqlite tier REFUSES to boot without SQLITE_PATH. Sessions are ephemeral by
# design here (the AUDIT log is what persists, via the bundle bind — Stage-4).
SQLITE_PATH=               # e.g. /tmp/agent-keep-sessions.sqlite3

# --- Proxy ingress hardening (ALL OPTIONAL; empty => default, issue #13) ------
# The unit pins KEEP_EGRESS_HOST to `egress-proxy` (the proxy's own internal-net
# alias) so the control port binds the INTERNAL interface ONLY — reachable only
# from the paired worker, never from the egress net (issue #11). This env value is
# not consulted for the bind (the unit sets it literally); leaving it blank is
# fine. HEAD_TIMEOUT_SECONDS (10) and MAX_CONNECTIONS (256) bound slowloris /
# half-open floods; blank => the runner default.
KEEP_EGRESS_HOST=                     # informational; unit pins egress-proxy
KEEP_EGRESS_PORT=                     # optional; blank => 3128
KEEP_EGRESS_HEAD_TIMEOUT_SECONDS=     # optional; blank => 10
KEEP_EGRESS_MAX_CONNECTIONS=          # optional; blank => 256

# --- Model provider key (SECRET VALUE — appended on the HOST at deploy) --------
# REQUIRED only for the live anthropic worker variant (specs/default-chatbot.live.yaml,
# provider: anthropic). The published static image never reads it. deploy.sh does
# NOT write this line; the operator appends it on the host (root:0600). NAME here,
# VALUE only on the host.
# ANTHROPIC_API_KEY=
